<odoo>
    <!-- ========================================================= -->
    <!-- REPORT TEMPLATE -->
    <!-- ========================================================= -->

    <template id="report_purchase_order_indent">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-set="company" t-value="o.company_id.sudo()"/>
                <div class="article"
                    t-att-data-oe-model="o and o._name"
                    t-att-data-oe-id="o and o.id"
                    t-att-data-oe-lang="o and o.env.context.get('lang')">

                    <div class="page" style="font-family:Arial, Helvetica, sans-serif; font-size:12px; color:#000000; margin:0; padding:0;">

                        <!-- ========================================================= -->
                        <!-- HEADER -->
                        <!-- ========================================================= -->

                        <table style="width:100%; border-collapse:collapse; border:1px solid #2b2b2b; margin-bottom:0px;">
                            <tr>
                                <!-- ========================================================= -->
                                <!-- LEFT LOGO -->
                                <!-- ========================================================= -->

                                <td style="width:24%; border-right:0.1px solid #fff; vertical-align:middle; text-align:center; padding:10px; height:90px;">
                                    <img t-if="company.logo"
                                        t-att-src="image_data_uri(company.logo)"
                                        style="max-width:265px; max-height:120px; width:auto; height:auto;"/>
                                </td>

                                <!-- ========================================================= -->
                                <!-- RIGHT COMPANY DETAILS -->
                                <!-- ========================================================= -->

                                <td style="width:76%; vertical-align:top; text-align:center; padding:8px 12px;">
                                    <!-- COMPANY NAME -->
                                    <div style="font-size:20px; color:#64BBEE; font-weight:bold; text-transform:uppercase; line-height:24px; margin-top:2px;">
                                        <span t-field="company.name"/>
                                    </div>

                                    <!-- ADDRESS -->
                                    <div style="font-size:13px; color:#000000; line-height:19px; margin-top:6px;">
                                        <t t-if="company.street">
                                            <span t-esc="company.street.split('GST')[0].strip()"/>,
                                        </t>
                                        <br/>
                                        <t t-if="company.street2">
                                            <span t-esc="company.street2.split('GST')[0].strip()"/>
                                            <span t-field="company.state_id.name"/> -
                                            <span t-field="company.zip"/>, <span t-field="company.country_id"/>
                                        </t>
                                    </div>

                                    <!-- EMAIL + WEBSITE -->
                                    <div style="font-size:13px; color:#000000; margin-top:6px; line-height:18px;">
                                        <span style="font-weight:normal;">Email :</span>
                                        <span t-field="company.email"/>
                                        <span style="padding-left:14px; font-weight:normal;">Website :</span>
                                        <span t-field="company.website"/>
                                    </div>
                                </td>
                            </tr>

                            <!-- Title -->
                            <tr style="border-top:1px solid #000000;"> 
                                <td colspan="2" style="border-left:1px solid #000000; border-right:1px solid #000000; 
                                            border-bottom:1px solid #000000; padding:14px 16px 12px 16px; text-align: center;"> 
                                    <div style="font-size:24px; color:#000000; font-weight:bold; line-height:24px; 
                                                text-transform:uppercase;"> 
                                                PURCHASE ORDER
                                    </div> 
                                </td> 
                            </tr>
                        </table>

                        <!-- ========================================================= -->
                        <!-- VENDOR + PO DETAILS -->
                        <!-- ========================================================= -->
                        
                        <table style="width:100%; border-collapse:collapse; margin-top:0px; border:1px solid #000000; border-top:none;">
                            <tr>
                                <!-- VENDOR DETAILS (LEFT) -->
                                <td style="width:70%; vertical-align:top; padding:8px; border-right:1px solid #000000;">
                                    <div style="min-height:80px;">
                                        <div style="margin-bottom:6px; font-size:14px;">
                                            <span style="color:#1d1da1; font-weight:bold;">Vendor :</span>
                                            <span t-if="o.partner_id.ref" t-field="o.partner_id.ref"/> 
                                            <span t-if="o.partner_id.ref"> - </span>
                                            <span t-field="o.partner_id.name" style="font-weight:bold;"/>
                                        </div>
                                        <div style="font-size:13px; line-height:18px;">
                                            <div t-field="o.partner_id.street"/>
                                            <div t-if="o.partner_id.street2" t-field="o.partner_id.street2"/>
                                            <div>
                                                <span t-field="o.partner_id.city"/> - <span t-field="o.partner_id.zip"/>, 
                                                <span t-field="o.partner_id.state_id.name"/>, <span t-field="o.partner_id.country_id.name"/>
                                            </div>
                                        </div>
                                        
                                        <table style="width:100%; border-collapse:collapse; border:0.1px solid #FFF; font-size:13px; margin-top:10px;">
                                            <tr>
                                                <td style="width:16%;">Contact Name</td>
                                                <td style="width:4%;">:</td>
                                                <td style="width:32%;"><span t-field="o.partner_id.person_name"/></td>
                                                <td style="width:16%;">STATE CODE</td>
                                                <td style="width:4%;">:</td>
                                                <td><span t-field="o.partner_id.state_id.l10n_in_tin"/></td>
                                            </tr>
                                            <tr>
                                                <td>Tel Number</td>
                                                <td>:</td>
                                                <td><span t-esc="o.partner_id.mobile or o.partner_id.phone"/></td>
                                                <td>GSTIN No.</td>
                                                <td>:</td>
                                                <td><span t-field="o.partner_id.vat"/></td>
                                            </tr>
                                            <tr>
                                                <td>Email Id</td>
                                                <td>:</td>
                                                <td colspan="4"><span t-field="o.partner_id.email"/></td>
                                            </tr>
                                        </table>
                                    </div>
                                </td>
                                
                                <!-- PO DETAILS (RIGHT) -->
                                <td style="width:30%; vertical-align:top; padding:8px;">
                                    <div style="min-height:130px;">
                                        <table style="width:100%; border-collapse:collapse; border:0.1px solid #FFF; font-size:13px;">
                                            <tr>
                                                <td style="width:40%;">P.O. No.</td>
                                                <td style="width:10%;">:</td>
                                                <td><span t-field="o.name"/></td>
                                            </tr>
                                            <tr>
                                                <td>P.O. Date</td>
                                                <td>:</td>
                                                <td><span t-field="o.date_order" t-options='{"widget": "date"}'/></td>
                                            </tr>
                                            <tr>
                                                <td>Ref No.</td>
                                                <td>:</td>
                                                <td><span t-field="o.partner_ref"/></td>
                                            </tr>
                                            <tr>
                                                <td>Ref Date</td>
                                                <td>:</td>
                                                <td> / / </td>
                                            </tr>
                                        </table>
                                    </div>
                                </td>
                            </tr>
                        </table>

                        <!-- ========================================================= -->
                        <!-- SHIPPING + BILLING ADDRESS -->
                        <!-- ========================================================= -->

                        <table style="width:100%; border-collapse:collapse; border:1px solid #000000; border-top:none; border-bottom:0.5px solid #000000; margin-bottom:0px;">
                            <tr>
                                <!-- SHIPPING ADDRESS -->
                                <td style="width:50%; vertical-align:top; border-right:1px solid #000000; padding:8px;">
                                    <div style="min-height:100px;">
                                        <div style="font-weight:bold; margin-bottom:5px; font-size:13px;">Shipping address :</div>
                                        <div style="line-height:18px; font-size:13px;">
                                            <t t-if="o.dest_address_id">
                                                <div t-field="o.dest_address_id.name"/>
                                                <div t-field="o.dest_address_id.street"/>
                                                <div t-if="o.dest_address_id.street2" t-field="o.dest_address_id.street2"/>
                                                <div>
                                                    <span t-field="o.dest_address_id.city"/> - <span t-field="o.dest_address_id.zip"/>, 
                                                    <span t-field="o.dest_address_id.state_id"/>, <span t-field="o.dest_address_id.country_id"/>
                                                </div>
                                                <div style="margin-top:4px;">GST NO : <span t-field="o.dest_address_id.vat"/></div>
                                            </t>
                                            <t t-else="">
                                                <div t-field="company.name"/>
                                                <div t-field="company.street"/>
                                                <div t-if="company.street2" t-field="company.street2"/>
                                                <div>
                                                    <span t-field="company.city"/> - <span t-field="company.zip"/>, 
                                                    <span t-field="company.state_id"/>, <span t-field="company.country_id"/>
                                                </div>
                                                <div style="margin-top:4px;">GST NO : <span t-field="company.vat"/></div>
                                            </t>
                                        </div>
                                    </div>
                                </td>
                                <!-- BILLING ADDRESS -->
                                <td style="width:50%; vertical-align:top; padding:8px;">
                                    <div style="min-height:100px;">
                                        <div style="font-weight:bold; margin-bottom:5px; font-size:13px;">Billing address :</div>
                                        <div style="line-height:18px; font-size:13px;">
                                            <div t-field="company.name"/>
                                            <div t-field="company.street"/>
                                            <div t-if="company.street2" t-field="company.street2"/>
                                            <div>
                                                <span t-field="company.city"/> - <span t-field="company.zip"/>, 
                                                <span t-field="company.state_id"/>, <span t-field="company.country_id"/>
                                            </div>
                                            <div style="margin-top:4px;">GST NO : <span t-field="company.vat"/></div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        </table>

                        <!-- ========================================================= -->
                        <!-- CALCULATIONS -->
                        <!-- ========================================================= -->
                        <t t-set="basic_total" t-value="0.0"/>
                        <t t-set="cgst" t-value="0.0"/>
                        <t t-set="sgst" t-value="0.0"/>

                        <t t-foreach="o.order_line" t-as="line">
                            <t t-set="line_is_special" t-value="False"/>
                            <t t-if="not line_is_special">
                                <t t-set="basic_total" t-value="basic_total + line.price_subtotal"/>
                            </t>
                            
                            <!-- Tax breakdown -->
                            <t t-foreach="line.taxes_id" t-as="tax">
                                <t t-set="tax_amount" t-value="line.price_subtotal * tax.amount / 100.0"/>
                                <t t-if="'CGST' in tax.name.upper()">
                                    <t t-set="cgst" t-value="cgst + tax_amount"/>
                                </t>
                                <t t-elif="'SGST' in tax.name.upper()">
                                    <t t-set="sgst" t-value="sgst + tax_amount"/>
                                </t>
                                <t t-elif="'GST' in tax.name.upper()">
                                    <t t-set="cgst" t-value="cgst + (tax_amount / 2)"/>
                                    <t t-set="sgst" t-value="sgst + (tax_amount / 2)"/>
                                </t>
                            </t>
                        </t>

                        <!-- ========================================================= -->
                        <!-- PRODUCT TABLE -->
                        <!-- ========================================================= -->
                        <table style="width:100%; border-collapse:collapse; margin-top:0px; border:1px solid #000000; font-size:13px;">
                            <thead>
                                <tr style="background:#efefef;">
                                    <th style="border:1px solid #000000; font-weight:bold; padding:6px; width:5%; text-align:center;">Sr No.</th>
                                    <th style="border:1px solid #000000; font-weight:bold; padding:6px; width:33%; text-align:center;">Material No. &amp; Material Description</th>
                                    <th style="border:1px solid #000000; font-weight:bold; padding:6px; width:6%; text-align:center;">HSN/SAC</th>
                                    <th style="border:1px solid #000000; font-weight:bold; padding:6px; width:6%; text-align:center;">HSN %</th>
                                    <th style="border:1px solid #000000; font-weight:bold; padding:6px; width:6%; text-align:center;">Uom</th>
                                    <th style="border:1px solid #000000; font-weight:bold; padding:6px; width:5%; text-align:right;">Quantity</th>
                                    <th style="border:1px solid #000000; font-weight:bold; padding:6px; width:8%; text-align:right;">Rate</th>
                                    <th style="border:1px solid #000000; font-weight:bold; padding:6px; width:10%; text-align:right;">Basic Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="sr_no" t-value="1"/>
                                <t t-foreach="o.order_line" t-as="line">
                                    <t t-set="line_is_special" t-value="False"/>
                                    <t t-if="'freight' in line.name.lower() or 'freight' in (line.product_id.name or '').lower()">
                                        <t t-set="line_is_special" t-value="True"/>
                                    </t>
                                    <t t-if="'insurance' in line.name.lower() or 'insurance' in (line.product_id.name or '').lower()">
                                        <t t-set="line_is_special" t-value="True"/>
                                    </t>
                                    
                                    <t t-if="not line_is_special">
                                        <t t-if="line.display_type == 'line_note'">
                                            <tr>
                                                <td style="border:1px solid #000000; padding:6px;"></td>
                                                <td colspan="7" style="border:1px solid #000000; padding:6px; font-style: italic;">
                                                    <span t-field="line.name" t-options='{"widget": "text"}'/>
                                                </td>
                                            </tr>
                                        </t>
                                        <t t-elif="line.display_type == 'line_section'">
                                            <tr style="background-color: #f2f2f2;">
                                                <td colspan="8" style="border:1px solid #000000; padding:6px; font-weight: bold;">
                                                    <span t-field="line.name" t-options='{"widget": "text"}'/>
                                                </td>
                                            </tr>
                                        </t>
                                        <t t-else="">
                                            <tr>
                                                <td style="border:1px solid #000000; padding:6px; vertical-align:top; text-align:center;">
                                                    <span t-esc="sr_no"/>
                                                </td>
                                                <td style="border:1px solid #000000; padding:6px; vertical-align:top;">
                                                    <div style="font-size: 13px;">
                                                        <span t-field="line.product_id.default_code"/>
                                                    </div>
                                                    <div style="margin-top:2px;">
                                                        <span t-field="line.product_id.name"/>
                                                    </div>
                                                    
                                                    <!-- Project No (Purple) -->
                                                    <div t-if="o.project_id" style="color: #800080; margin-top: 2px;">
                                                        Project No : <span t-field="o.project_id.name"/>
                                                    </div>

                                                    <!-- Description / Technical Details (Stripping product name to avoid duplication) -->
                                                    <t t-set="description" t-value="line.name or ''"/>
                                                    <t t-set="prod_name" t-value="line.product_id.name or ''"/>
                                                    <t t-if="description.startswith(prod_name)">
                                                        <t t-set="description" t-value="description[len(prod_name):].strip()"/>
                                                    </t>
                                                    <div t-if="description" style="margin-top:4px; font-size:11px; line-height:1.3;">
                                                        <span t-esc="description" t-options='{"widget": "text"}'/>
                                                    </div>
                                                </td>
                                                <td style="border:1px solid #000000; padding:6px; vertical-align:top; text-align:center;">
                                                    <span t-field="line.product_id.l10n_in_hsn_code"/>
                                                </td>
                                                <td style="border:1px solid #000000; padding:6px; vertical-align:top; text-align:center;">
                                                    <span t-esc="', '.join([(tax.name or '') for tax in line.taxes_id])"/>
                                                </td>
                                                <td style="border:1px solid #000000; padding:6px; vertical-align:top; text-align:center;">
                                                    <span t-field="line.product_uom"/>
                                                </td>
                                                <td style="border:1px solid #000000; padding:6px; vertical-align:top; text-align:right;">
                                                    <span t-field="line.product_qty"/>
                                                </td>
                                                <td style="border:1px solid #000000; padding:6px; vertical-align:top; text-align:right;">
                                                    <span t-field="line.price_unit" t-options='{"widget":"float","precision":2}'/>
                                                </td>
                                                <td style="border:1px solid #000000; padding:6px; vertical-align:top; text-align:right;">
                                                    <span t-field="line.price_subtotal" t-options='{"widget": "float", "precision": 2}'/>
                                                </td>
                                            </tr>
                                            <t t-set="sr_no" t-value="sr_no + 1"/>
                                        </t>
                                    </t>
                                </t>
                            </tbody>
                        </table>

                        <!-- TOTAL ROW -->
                        <table style="width:100%; border-collapse:collapse; margin-top:0px; border-left:1px solid #000; border-right:1px solid #000;">
                            <tr>
                                <td style="width:90%; text-align:right; border-bottom:1px solid #000; border-right:0px solid #fff; padding:6px; color:#1d1da1; font-weight:bold; font-size:13px;">
                                    Total :
                                </td>
                                <td style="width:12%; text-align:right; padding:6px; font-size:13px; border-bottom:1px solid #000;">
                                    <t t-esc="basic_total" t-options='{"widget": "float", "precision": 2}'/>
                                </td>
                            </tr>
                        </table>

                        <!-- ========================================================= -->
                        <!-- TOTAL SECTION -->
                        <!-- ========================================================= -->

                        <table style="width:100%; border-collapse:collapse; margin-top:0px;">
                            <tr>
                                <!-- LEFT - Terms & Conditions -->
                                <td style="width:70%; vertical-align:top; border-top:0.5px solid #000000; border-left:1px solid #000000; 
                                           border-bottom:1px solid #000000; border-right:1px solid #000000; padding:8px;">
                                    <div style="font-weight:bold; margin-bottom:6px; font-size:13px;">
                                        Terms &amp; Conditions :
                                    </div>
                                    <table style="width:100%; border-collapse:collapse; border:0.1px solid #fff; font-size:13px;">
                                        <tr>
                                            <td style="width:20%;">PAYMENT TERMS</td>
                                            <td style="width:3%;">:</td>
                                            <td><span t-field="o.payment_term_id"/></td>
                                        </tr>
                                        <tr>
                                            <td>DILEVERY TERMS</td>
                                            <td>:</td>
                                            <td><span t-field="o.incoterm_id"/></td>
                                        </tr>
                                        <tr>
                                            <td>TRANSPORT</td>
                                            <td>:</td>
                                            <td>Extra</td>
                                        </tr>
                                        <tr>
                                            <td>MTC</td>
                                            <td>:</td>
                                            <td>
                                                Test Certificates and Inspection Report Required With Material.
                                            </td>
                                        </tr>
                                    </table>
                                </td>

                                <!-- RIGHT - Taxes & Grand Total -->
                                <td style="width:30%; vertical-align:top; border-top:1px solid #000000; border-bottom:1px solid #000000; border-right:1px solid #000;">
                                    <table style="width:100%; border:1px solid #fff; font-size:13px;">
                                        <tr>
                                            <td colspan="3" style="padding:6px; font-weight:bold; font-size:13px;">
                                                Taxes :
                                            </td>
                                        </tr>
                                        <t t-if="cgst">
                                            <tr>
                                                <td style="padding:2px 6px; padding-left:20px;">CGST</td>
                                                <td>:</td>
                                                <td style="text-align:right; padding:2px 6px;">
                                                    <t t-esc="cgst" t-options='{"widget": "float", "precision": 2}'/>
                                                </td>
                                            </tr>
                                        </t>
                                        <t t-if="sgst">
                                            <tr>
                                                <td style="padding:2px 6px; padding-left:20px;">SGST</td>
                                                <td>:</td>
                                                <td style="text-align:right; padding:2px 6px;">
                                                    <t t-esc="sgst" t-options='{"widget": "float", "precision": 2}'/>
                                                </td>
                                            </tr>
                                        </t>
                                        <tr style="border-top:1px solid #000;">
                                            <td style="padding:6px; font-weight:bold; font-size:15px;">Grand Total</td>
                                            <td>:</td>
                                            <td style="padding:6px; text-align:right; font-weight:bold; font-size:14px;">
                                                <span t-field="o.amount_total" t-options='{"widget": "float", "precision": 2}'/>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>
                        </table>

                        <!-- ========================================================= -->
                        <!-- AMOUNT IN WORD -->
                        <!-- ========================================================= -->

                        <table style="width:100%; border-collapse:collapse; border-left:1px solid #000000; 
                                      border-right:1px solid #000000; border-bottom:1px solid #000000;">
                            <tr>
                                <td style="padding:8px; font-size:13px;">
                                    <strong>
                                        Amount chargeable(in words):
                                    </strong>
                                    <span t-esc="o.currency_id.amount_to_text(o.amount_total)"/>
                                </td>
                            </tr>
                        </table>

                        <!-- ========================================================= -->
                        <!-- NARRATION -->
                        <!-- ========================================================= -->

                        <table style="width:100%; border-collapse:collapse; border-left:1px solid #000000; 
                                      border-right:1px solid #000000; border-top:1px solid #000000;">
                            <tr>
                                <td style="padding:8px; height:120px; vertical-align:top; font-size:13px;">
                                    <strong>Narration :</strong>
                                    <div style="margin-top:4px;">
                                        <span t-field="o.notes"/>
                                    </div>
                                </td>
                            </tr>
                        </table>

                        <!-- ========================================================= -->
                        <!-- SIGNATURE -->
                        <!-- ========================================================= -->

                        <table style="width:100%; border-collapse:collapse; border:1px solid #000; page-break-inside: avoid; break-inside: avoid;">
                            <tr>
                                <td colspan="3" style="padding:8px; text-align:right; color:#9d348b; font-size:13px; border-bottom:0.1px solid #fff;">
                                    For <span t-field="company.name"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="width:33%; height:80px; border-right:0.1px solid #fff; border-top:0.1px solid #fff; vertical-align:bottom; text-align:center; padding-bottom:8px;">
                                    <div style="font-size:13px; margin-bottom:4px; text-transform:uppercase;">
                                        <span t-field="o.user_id.name"/>
                                    </div>
                                    <div style="font-size:13px;">Prepared By</div>
                                </td>
                                <td style="width:33%; vertical-align:bottom; border-right:0.1px solid #fff; border-top:0.1px solid #fff; text-align:center; padding-bottom:8px;">
                                    <div style="font-size:13px;">Verified By</div>
                                </td>
                                <td style="width:34%; vertical-align:bottom; text-align:center; border-top:0.1px solid #fff; padding-bottom:8px;">
                                    <div style="font-size:13px; font-weight:bold;">Authorised Signatory</div>
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>
                <!-- ================================================== -->
                <!-- FOOTER -->
                <!-- ================================================== -->
                <div class="footer" style="width: 100%; font-size: 11px; font-family: Arial, Helvetica, sans-serif; border-top: 1px solid #fff;">
                    <table style="width: 100%; border-collapse: collapse; border:1px solid #fff; margin-top: 5px;">
                        <tr>
                            <td style="width: 20%;"></td>
                            <td style="width: 60%; text-align: center; vertical-align: middle;">
                                This is a computer generated document hence no signature is required.
                            </td>
                            <td style="width: 20%; text-align: right; vertical-align: middle;">
                                Page <span class="page"/> of <span class="topage"/>
                            </td>
                        </tr>
                    </table>
                </div>
            </t>
        </t>
    </template>

    <!-- ========================================================= -->
    <!-- REPORT ACTION -->
    <!-- ========================================================= -->

    <record id="action_report_purchase_order_indent" model="ir.actions.report">
        <field name="name">Purchase Order New Format</field>
        <field name="model">purchase.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">purchase_report.report_purchase_order_indent</field>
        <field name="report_file">purchase_report.report_purchase_order_indent</field>
        <field name="binding_model_id" ref="purchase.model_purchase_order"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="purchase_report.paperformat_purchase_order_indent"/>
        <field name="print_report_name">
            'Purchase Order - ' + (object.name or 'PO') + ' - ' + (object.partner_id.name or 'Customer')
        </field>
    </record>

