<odoo>
    <record id="view_sale_order_form_documents" model="ir.ui.view">
        <field name="name">sale.order.form.documents</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="options">{'no_create': True, 'no_create_edit': True}</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']//field[@name='product_template_id']" position="attributes" fail_on_error="0">
                <attribute name="options">{'no_create': True, 'no_create_edit': True}</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']//field[@name='product_id']" position="attributes" fail_on_error="0">
                <attribute name="options">{'no_create': True, 'no_create_edit': True}</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']//field[@name='tax_id']" position="after">
                <field name="gst_percent"/>
            </xpath>
            <xpath expr="//page[@name='other_information']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//page[@name='optional_products']" position="attributes" fail_on_error="0">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Documents">
                    <group string="HEADER">
                        <!-- Upload -->
                        <field name="header_file" filename="header_filename" options="{'no_open': True, 'accepted_file_extensions': '.pdf'}"/>
                        <!-- Show filename (clean, no duplicate) -->
                        <field name="header_filename" invisible="1"/>
                    </group>

                    <!-- FOOTER -->
                    <group string="FOOTER">
                        <field name="footer_file" filename="footer_filename" options="{'no_open': True, 'accepted_file_extensions': '.pdf'}"/>
                        <field name="footer_filename" invisible="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Hide New/Create button from Sales and Purchase product views -->
    <record id="sale.product_template_action" model="ir.actions.act_window">
        <field name="context">{'create': False}</field>
    </record>

    <record id="purchase.product_normal_action_puchased" model="ir.actions.act_window">
        <field name="context">{'create': False}</field>
    </record>

    <record id="product.product_normal_action_sell" model="ir.actions.act_window">
        <field name="context">{'create': False}</field>
    </record>

    <record id="purchase.product_product_action" model="ir.actions.act_window">
        <field name="context">{'create': False}</field>
    </record>

    <!-- Manufacturing (MRP) Overrides -->
    <record id="mrp.product_template_action" model="ir.actions.act_window">
        <field name="context">{'create': False}</field>
    </record>

    <record id="mrp.mrp_product_variant_action" model="ir.actions.act_window">
        <field name="context">{'create': False}</field>
    </record>

    <!-- Accounting / Invoicing Overrides -->
    <record id="account.product_product_action_sellable" model="ir.actions.act_window">
        <field name="context">{'create': False}</field>
    </record>

    <record id="account.product_product_action_purchasable" model="ir.actions.act_window">
        <field name="context">{'create': False}</field>
    </record>

    <!-- Restrict inline product creation on Invoice/Bill lines -->
    <record id="view_move_form_inherit_restrict_product" model="ir.ui.view">
        <field name="name">account.move.form.inherit.restrict.product</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_line_ids']//field[@name='product_id']" position="attributes">
                <attribute name="options">{'no_create': True, 'no_create_edit': True}</attribute>
            </xpath>
        </field>
    </record>
</odoo>