<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_revision" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.revision</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <!-- Add smart button for revisions -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_revisions" type="object" class="oe_stat_button" icon="fa-history" invisible="revision_count == 0">
                    <field name="revision_count" widget="statinfo" string="Revisions"/>
                </button>
            </xpath>
            
            <!-- Add original_order_id to Other Info or right after the partner_id in title -->
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="revision_number_display" readonly="1"/>
                <field name="original_order_id" invisible="not original_order_id" readonly="1"/>
            </xpath>
        </field>
    </record>

    <!-- Separate view for the tree/list view -->
    <record id="view_quotation_tree_inherit_revision" model="ir.ui.view">
        <field name="name">sale.order.tree.inherit.revision</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_quotation_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="revision_number_display" string="Rev" optional="show"/>
            </xpath>
            <xpath expr="//field[@name='state']" position="after">
                <button name="action_preview_sale_order" string="Preview" type="object" icon="fa-eye"/>
            </xpath>
        </field>
    </record>

    <!-- Submit Revision Button -->
    <record id="view_order_form_inherit_revison_submit" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.revison.submit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button
                    name="action_submit_revision"
                    type="object"
                    string="Submit"
                    class="btn btn-primary"
                    invisible="not show_submit_button or state == 'sale'"/>
            </xpath>
        </field>
    </record>

    <!-- Custom Tree/List view for Revisions -->
    <record id="view_revision_order_tree" model="ir.ui.view">
        <field name="name">sale.order.tree.revision</field>
        <field name="model">sale.order</field>
        <field name="arch" type="xml">
            <list string="Revisions" create="0" delete="0" edit="0" duplicate="0">
                <field name="name"/>
                <field name="revision_number_display" string="Revision"/>
                <field name="date_order" widget="date"/>
                <field name="partner_id"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="amount_total" sum="Total" widget="monetary"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'sale'"/>
                <button name="action_preview_sale_order" string="Preview" type="object" icon="fa-eye"/>
            </list>
        </field>
    </record>

</odoo>
