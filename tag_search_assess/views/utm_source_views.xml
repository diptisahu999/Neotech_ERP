<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="utm_source_view_tree_inherit_delete" model="ir.ui.view">
        <field name="name">utm.source.view.tree.inherit.delete</field>
        <field name="model">utm.source</field>
        <field name="inherit_id" ref="utm.utm_source_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list|//tree" position="inside">
                <field name="can_search_more_tags" column_invisible="1"/>
                <button name="action_delete_source" type="object" icon="fa-trash" title="Delete" 
                        confirm="Are you sure you want to delete this source?" 
                        invisible="not can_search_more_tags"
                        class="text-danger"/>
            </xpath>
        </field>
    </record>
</odoo>
