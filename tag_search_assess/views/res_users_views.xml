<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_users_form_inherit_tag_search" model="ir.ui.view">
        <field name="name">res.users.form.inherit.tag.search</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='access_rights']" position="inside">


                <group string="Tag Permissions">
                    <field name="can_search_more_tags"/>
                </group>
            </xpath>

        </field>
    </record>
</odoo>
