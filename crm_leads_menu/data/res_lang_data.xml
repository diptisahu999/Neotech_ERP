<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Update English (US) date and datetime format to dd/mm/yyyy -->
    <!-- We remove noupdate="1" to force the update if it didn't take effect previously -->
        <record id="base.lang_en" model="res.lang">
            <field name="date_format">%d/%m/%Y</field>
            <field name="time_format">%H:%M:%S</field>
        </record>
</odoo>
